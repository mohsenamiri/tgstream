# ── Required ──────────────────────────────────────────────────────────────────
# Telegram MTProto credentials  →  https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your bot token  →  from @BotFather on Telegram
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Random secret for signing download URLs  →  openssl rand -hex 32
SECRET_KEY=replace_with_64_hex_chars

# The public HTTPS URL where this service is reachable
# (no trailing slash)
PUBLIC_URL=https://my-tgstream.onrender.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Your numeric Telegram user ID(s), comma-separated
# Get yours from @userinfobot — leave empty to allow ALL users (not safe)
ALLOWED_USERS=123456789

# HTTP port — Render uses 10000 by default, most others use 8080
PORT=10000
